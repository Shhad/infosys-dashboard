# Frontend build-time configuration.
#
# IMPORTANT: these VITE_* variables are inlined into the JS bundle during
# `vite build` — they are NOT read at runtime. The production API addresses must
# therefore be known at build time (see SPEC §6 / §12.4). Local and AWS builds
# use different values. Copy this file to `.env` for local development.

# auth-service base URL (register, login, /users/me, /admin/users)
VITE_AUTH_BASE_URL=http://localhost:8000

# task-service base URL (/api/cards ...)
VITE_API_BASE_URL=http://localhost:8080
