# Copy to .env and adjust. Never commit the real .env (secrets — NFR-5).

# ---- shared ----
CORS_ORIGINS=http://localhost:3000

# ---- auth-service ----
AUTH_DB_URL=postgresql://auth:auth@auth-db:5432/authdb
AUTH_DB_USER=auth
AUTH_DB_PASSWORD=auth
AUTH_DB_NAME=authdb
JWT_PRIVATE_KEY_PATH=/keys/private.pem
JWT_PUBLIC_KEY_PATH=/keys/public.pem
JWT_EXPIRES_IN=3600
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change-me

# ---- task-service (iteration 2) ----
TASK_DB_URL=jdbc:postgresql://task-db:5432/taskdb
TASK_DB_USER=task
TASK_DB_PASSWORD=task
TASK_DB_NAME=taskdb
# RS256 public key for local JWT validation (NFR-2), shared via the `keys` volume:
JWT_PUBLIC_KEY_PATH=/keys/public.pem
# Fallback key source (loaded once at startup), leave blank to use the PEM above:
AUTH_JWKS_URL=

# ---- frontend (build-time, iteration 3) ----
VITE_API_BASE_URL=http://localhost:8080
VITE_AUTH_BASE_URL=http://localhost:8000
